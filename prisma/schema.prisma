generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model CarreraDepartamento {
  id             Int       @id @default(autoincrement())
  carreraId      BigInt    // viene de la BD externa de carreras
  departamentoId Int       // viene de la BD externa de academico
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}
