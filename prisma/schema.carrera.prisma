// prisma/schema.carrera.prisma

// =======================
// Conexion MySQL carrera
// =======================
datasource carrera {
  provider = "mysql"
  url      = env("DATABASE_CARRERA_URL")
}

generator carreraClient {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
  output   = "../generated/carrera"
}

model carrera {
  id                   BigInt                 @id @default(autoincrement()) @carrera.UnsignedBigInt
  clave                String                 @carrera.VarChar(10)
  plan                 String                 @carrera.VarChar(8)
  nombre               String                 @carrera.VarChar(150)
  created_at           DateTime?              @carrera.Timestamp(0)
  updated_at           DateTime?              @carrera.Timestamp(0)
  atributos_egreso     Boolean                @default(false)
}