// =======================
// Conexión MySQL - Nombre
// =======================

datasource nombre {
  provider = "mysql"
  url      = env("DATABASE_NOMBRE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "./generated/nombre"
}

model alumno {
  id     Int     @id @default(autoincrement()) // necesario para Prisma
  codigo String
  nombre String?
  ap     String?
  am     String?
  rfid   String?
}
